# Privy (https://dashboard.privy.io) — App ID and App secret must be from the same Privy app
VITE_PRIVY_APP_ID=
# App secret for serverless / Node only (Dashboard → Your app → Configuration → App secret). Set on Vercel as PRIVY_APP_SECRET — never use VITE_ prefix.
PRIVY_APP_SECRET=
# Optional: same as VITE_PRIVY_APP_ID if you want a non-VITE name in server env only
# PRIVY_APP_ID=
# Embedded-wallet mints: request Privy native gas sponsorship (Dashboard → Gas sponsorship; enable client-sponsored txs). Set to false to force user-paid gas on embedded wallets.
# VITE_PRIVY_GAS_SPONSORSHIP=false

# Mapbox – default public token (pk.*) from https://account.mapbox.com/access-tokens/ — not a secret (sk.*) token
VITE_MAPBOX_ACCESS_TOKEN=

# Base RPC (https://docs.base.org)
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Chain selection: base (mainnet) | base-sepolia (testnet) — must match deployed contracts, indexer, and Vercel API (see CHAIN below)
VITE_CHAIN=base

# Contract (fill after deploy)
VITE_MEMORY_ARCHIVE_CONTRACT_ADDRESS=
VITE_MEMORY_REGISTRY_CONTRACT_ADDRESS=

# Indexer / API — local: `cd indexer && npm run dev`. Vercel: same deployment URL, e.g. https://your-app.vercel.app (rewrites expose /memories, /health)
VITE_INDEXER_URL=http://localhost:8787

# When the UI runs on Vite only (`npm run dev`), proxy `/api` → 3000 by default; override origin if needed:
# VITE_API_BASE_URL=https://your-app.vercel.app

# Supabase (Vercel serverless only — not exposed to the browser)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ADMIN_SESSION_SECRET=at-least-16-chars-for-admin-session-hmac
# Optional HMAC for claim coupons (defaults to ADMIN_SESSION_SECRET)
# CLAIM_COUPON_SECRET=

# Server / long-running indexer: same network as VITE_CHAIN (base = mainnet). Vercel serverless reads CHAIN, or VITE_CHAIN if CHAIN is unset.
# CHAIN=base
# MEMORY_REGISTRY_ADDRESS=

# Storage – Pinata (https://pinata.cloud): JWT uses v3 upload API; OR legacy api key + secret for pinning API
VITE_PINATA_JWT=
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET=

# Optional fallback: NFT.Storage (https://nft.storage)
# VITE_NFT_STORAGE_API_KEY=
