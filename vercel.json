{
  "crons": [{ "path": "/api/cron/sync", "schedule": "* * * * *" }],
  "functions": {
    "api/cron/sync.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/memories/:memoryId/image", "destination": "/api/memories/:memoryId/image" },
    { "source": "/memories/:memoryId/seed", "destination": "/api/memories/:memoryId/seed" },
    { "source": "/memories", "destination": "/api/memories" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
